# Your Stellar keypair (from Stellar Lab or your wallet)
STELLAR_SECRET_KEY=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
STELLAR_PUBLIC_KEY=GXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# A strong random secret for signing JWTs (generate with: openssl rand -hex 32)
JWT_SECRET=your_super_secret_jwt_key_here

# Your server's domain — this is what goes in stellar.toml and SEP-10
# On AWS EC2 this would be your public DNS e.g: ec2-xx-xx-xx-xx.compute.amazonaws.com
# Or your custom domain if using Route 53
CLIENT_DOMAIN=your-domain-here.com

# Port to run the server on (AWS EC2 usually uses 3000 or 8080, exposed via nginx on 443)
PORT=3000
